# Copy to .env or set in Netlify UI. Never commit .env.

# Required: Facebook Conversions API
FACEBOOK_PIXEL_ID=
FACEBOOK_ACCESS_TOKEN=

# Required: Offer/affiliate redirect (used by go-firstquote and as server fallback)
OFFER_REDIRECT_URL=

# Optional: Site base URL (defaults to https://policypulse.online if unset)
SITE_URL=https://your-site.netlify.app

# Optional: Fallback URL returned to client if redirect fails (e.g. same as OFFER_REDIRECT_URL)
OFFER_FALLBACK_URL=

# Optional: Redis (if you add caching later)
# REDIS_URL=redis://...
